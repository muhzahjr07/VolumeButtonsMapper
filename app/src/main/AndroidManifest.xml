<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_logo_lush_green_adaptive"
        android:roundIcon="@mipmap/ic_logo_lush_green_adaptive"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VolumePower">
        
        <activity
            android:name=".SplashActivity"
            android:exported="true" />

        <activity-alias
            android:name=".SplashActivityLushGreen"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_lush_green_adaptive"
            android:roundIcon="@mipmap/ic_logo_lush_green_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityMidnightBlue"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_midnight_blue_adaptive"
            android:roundIcon="@mipmap/ic_logo_midnight_blue_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityPurpleNebula"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_purple_nebula_adaptive"
            android:roundIcon="@mipmap/ic_logo_purple_nebula_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityCrimsonSunset"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_crimson_sunset_adaptive"
            android:roundIcon="@mipmap/ic_logo_crimson_sunset_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityEmeraldDream"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_emerald_dream_adaptive"
            android:roundIcon="@mipmap/ic_logo_emerald_dream_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityPitchBlack"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_pitch_black_adaptive"
            android:roundIcon="@mipmap/ic_logo_pitch_black_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityDarkGray"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_dark_gray_adaptive"
            android:roundIcon="@mipmap/ic_logo_dark_gray_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SplashActivityDeepNavy"
            android:targetActivity=".SplashActivity"
            android:icon="@mipmap/ic_logo_deep_navy_adaptive"
            android:roundIcon="@mipmap/ic_logo_deep_navy_adaptive"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <service
            android:name=".VolumePowerAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:label="@string/accessibility_service_name">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
